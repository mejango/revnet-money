{
  "name": "revnet-money",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.23.1 <23"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run env:check:build && next build --webpack",
    "build:browser": "node scripts/build-browser.mjs",
    "start": "npm run env:check:runtime && next start",
    "start:standalone": "npm run env:check:runtime && node .next/standalone/server.js",
    "lint": "eslint . --max-warnings=0",
    "format:ratchet": "node scripts/check-format-ratchet.mjs",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "npm run wallet-writes:check && vitest run --coverage",
    "test:browser": "playwright test",
    "browser:fixture": "node scripts/browser-fixture-server.mjs",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "dependencies:check": "npm ls --depth=0",
    "protocol:check": "node scripts/check-protocol-deployments.mjs",
    "wallet-writes:check": "node scripts/check-wallet-write-sites.mjs",
    "bundle:check": "node scripts/check-client-bundle.mjs",
    "standalone:check": "node scripts/check-standalone.mjs",
    "standalone:stage": "node scripts/stage-standalone.mjs",
    "deployment:check": "node scripts/check-deployment-config.mjs",
    "env:check:build": "node --env-file-if-exists=.env.local scripts/validate-env.mjs build",
    "env:check:runtime": "node --env-file-if-exists=.env.local scripts/validate-env.mjs runtime",
    "env:test": "node scripts/test-validate-env.mjs",
    "check": "npm run dependencies:check && npm run env:test && npm run deployment:check && npm run typecheck && npm run lint && npm run format:ratchet && npm run protocol:check && npm run test:ci && npm run build:browser && npm run standalone:check && npm run bundle:check && npm run test:browser",
    "ts:compile": "tsc",
    "format:write": "prettier --write \"**/*.{js,jsx,mjs,ts,tsx,json,css,scss}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,ts,tsx,json,css,scss}\""
  },
  "dependencies": {
    "@bananapus/nana-sdk-core": "1.4.0",
    "@tanstack/react-query": "5.101.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.3.0",
    "dompurify": "^3.4.12",
    "fpnum": "^1.0.0",
    "lucide-react": "^0.395.0",
    "next": "16.2.11",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.2.0",
    "viem": "2.55.8",
    "wagmi": "3.7.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "22.20.1",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^16.3.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.11",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "postcss": "8.5.22",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-tailwindcss": "0.7.4",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.1.5"
  },
  "overrides": {
    "brace-expansion@<2": "1.1.16",
    "brace-expansion@>=2 <3": "2.1.2",
    "glob@>=10 <11": "10.5.0",
    "minimatch@>=9 <10": "9.0.9",
    "picomatch@<3": "2.3.2",
    "sharp@<0.35": "0.35.3"
  },
  "packageManager": "npm@10.9.8"
}
